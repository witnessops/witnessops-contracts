{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://contracts.witnessops.com/schemas/evidence-manifest.schema.json",
  "title": "WitnessOps Evidence Manifest",
  "type": "object",
  "additionalProperties": false,
  "required": ["manifest_version", "workflow_class", "proof_run_id", "source_systems", "artifacts"],
  "properties": {
    "manifest_version": {
      "type": "string",
      "pattern": "^witnessops\\.evidence_manifest\\.v\\d+$"
    },
    "workflow_class": {
      "type": "string",
      "pattern": "^[a-z][a-z0-9_]*$"
    },
    "proof_run_id": {
      "type": "string",
      "pattern": "^pr_[A-Za-z0-9_:-]+$"
    },
    "source_systems": {
      "type": "array",
      "items": { "type": "string", "minLength": 1 },
      "minItems": 1,
      "uniqueItems": true
    },
    "authority": { "$ref": "#/$defs/host_triage_authority" },
    "target": { "$ref": "#/$defs/host_triage_target" },
    "collector": { "$ref": "#/$defs/host_triage_collector" },
    "launcher": { "$ref": "#/$defs/host_triage_launcher" },
    "collection_profile": { "$ref": "#/$defs/host_triage_collection_profile" },
    "declared_exclusions": {
      "type": "array",
      "items": { "type": "string", "pattern": "^[a-z][a-z0-9_]*$" },
      "uniqueItems": true
    },
    "declared_side_effects": {
      "type": "array",
      "items": { "type": "string", "minLength": 1 },
      "uniqueItems": true
    },
    "host_clock": {
      "type": "object",
      "additionalProperties": false,
      "required": ["trust_status"],
      "properties": {
        "trust_status": {
          "type": "string",
          "enum": ["trusted", "untrusted", "unknown"]
        },
        "observed_timezone": {
          "type": "string",
          "minLength": 1
        },
        "notes": {
          "type": "string"
        }
      }
    },
    "artifacts": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["artifact_id", "artifact_type", "source_system", "path", "sha256"],
        "properties": {
          "artifact_id": {
            "type": "string",
            "pattern": "^[a-z][a-z0-9_]*$"
          },
          "artifact_type": {
            "type": "string",
            "minLength": 1
          },
          "artifact_class": {
            "type": "string",
            "pattern": "^[a-z][a-z0-9_]*$",
            "not": {
              "enum": [
                "credentials",
                "browser_cookies",
                "oauth_tokens",
                "private_keys",
                "password_manager_data",
                "screenshots",
                "clipboard",
                "full_user_documents",
                "full_memory_dump"
              ]
            }
          },
          "source_system": {
            "type": "string",
            "minLength": 1
          },
          "path": {
            "type": "string",
            "minLength": 1
          },
          "sha256": {
            "type": "string",
            "pattern": "^sha256:[a-f0-9]{64}$"
          },
          "collector_method": {
            "type": "string",
            "minLength": 1
          },
          "sensitivity": {
            "type": "string",
            "enum": ["low", "medium", "high"]
          }
        }
      }
    }
  },
  "allOf": [
    {
      "if": {
        "properties": {
          "workflow_class": { "const": "host_triage_evidence_collection" }
        },
        "required": ["workflow_class"]
      },
      "then": {
        "required": [
          "authority",
          "target",
          "collector",
          "launcher",
          "collection_profile",
          "declared_exclusions",
          "declared_side_effects",
          "host_clock"
        ],
        "properties": {
          "artifacts": {
            "items": {
              "required": ["artifact_class", "collector_method", "sensitivity"]
            }
          }
        }
      }
    }
  ],
  "$defs": {
    "host_triage_authority": {
      "type": "object",
      "additionalProperties": false,
      "required": ["authorization_id", "case_id", "operator_id", "collection_profile_id"],
      "properties": {
        "authorization_id": { "type": "string", "minLength": 1 },
        "case_id": { "type": "string", "minLength": 1 },
        "operator_id": { "type": "string", "minLength": 1 },
        "collection_profile_id": { "type": "string", "pattern": "^[a-z][a-z0-9_]*$" },
        "authorization_window": {
          "type": "object",
          "additionalProperties": false,
          "required": ["start_utc", "end_utc"],
          "properties": {
            "start_utc": { "type": "string", "format": "date-time" },
            "end_utc": { "type": "string", "format": "date-time" }
          }
        }
      }
    },
    "host_triage_target": {
      "type": "object",
      "additionalProperties": false,
      "required": ["claimed_hostname", "asset_id"],
      "properties": {
        "claimed_hostname": { "type": "string", "minLength": 1 },
        "asset_id": { "type": "string", "minLength": 1 },
        "os_family": { "type": "string", "enum": ["windows", "linux", "macos", "unknown"] }
      }
    },
    "host_triage_collector": {
      "type": "object",
      "additionalProperties": false,
      "required": ["name", "version", "hash", "signature_key_id", "signature_status"],
      "properties": {
        "name": { "type": "string", "minLength": 1 },
        "version": { "type": "string", "minLength": 1 },
        "hash": { "type": "string", "pattern": "^sha256:[a-f0-9]{64}$" },
        "signature_key_id": { "type": "string", "minLength": 1 },
        "signature_status": { "type": "string", "enum": ["valid", "invalid", "not_supplied"] }
      }
    },
    "host_triage_launcher": {
      "type": "object",
      "additionalProperties": false,
      "required": ["type", "boundary"],
      "properties": {
        "type": {
          "type": "string",
          "enum": ["manual_terminal", "usb_hid_keyboard_launcher", "mde_live_response", "velociraptor"]
        },
        "identifier": { "type": "string" },
        "payload_hash": { "type": "string", "pattern": "^sha256:[a-f0-9]{64}$" },
        "boundary": { "type": "string", "minLength": 1 }
      }
    },
    "host_triage_collection_profile": {
      "type": "object",
      "additionalProperties": false,
      "required": ["profile_id", "prohibited_classes"],
      "properties": {
        "profile_id": { "type": "string", "pattern": "^[a-z][a-z0-9_]*$" },
        "prohibited_classes": {
          "type": "array",
          "items": { "type": "string", "pattern": "^[a-z][a-z0-9_]*$" },
          "minItems": 1,
          "uniqueItems": true
        }
      }
    }
  }
}
